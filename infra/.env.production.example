# ============================================================================
# TezKetKaz STAGING / PRODUCTION env file
# ============================================================================
# Скопируй этот файл в infra/.env и заполни значения. .env не уходит в git.
#
# Команды для генерации секретов (выполни на сервере один раз):
#   openssl rand -hex 32                              # JWT_SECRET
#   openssl rand -base64 32                           # INTEGRATION_ENC_KEY
#   openssl rand -hex 32                              # TELEGRAM_WEBHOOK_SECRET
#   openssl rand -base64 24 | tr -d '/=+' | cut -c1-32  # POSTGRES_PASSWORD
# ============================================================================

# ─── Домен ──────────────────────────────────────────────────────────────────
# Под этим именем Caddy получит SSL. DNS A-record должен указывать на IP
# сервера ДО запуска docker compose, иначе Let's Encrypt откажет.
DOMAIN=staging.tezketkaz.uz
# Email для Let's Encrypt-уведомлений (срок действия, ошибки renewal)
ADMIN_EMAIL=you@example.com

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=tezketkaz
POSTGRES_PASSWORD=__GENERATE_ME__
POSTGRES_DB=tezketkaz

# ─── Backend ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# JWT — 64 hex chars
JWT_SECRET=__GENERATE_ME__
JWT_EXPIRES_IN=30d

# AES-256-GCM ключ для шифрования POS credentials. 32 байта в base64.
INTEGRATION_ENC_KEY=__GENERATE_ME__

# Redis (адрес и порт в docker network)
REDIS_HOST=redis
REDIS_PORT=6379

# ─── SMS Gateway (Eskiz.uz) ────────────────────────────────────────────────
# Пока не настроено — используем mock. Telegram-вход работает без SMS.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546
USE_MOCK_SMS=true

# ─── Платежи ────────────────────────────────────────────────────────────────
# Пока mock — реальные ключи получишь после подписания договоров с
# Click / Payme / Uzum Pay. До тех пор работает только cash-метод оплаты.
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_KEY=
UZUM_MERCHANT_ID=
USE_MOCK_PAYMENTS=true

# ─── Yandex ────────────────────────────────────────────────────────────────
# Три раздельных ключа. Geocoder нужен на бэкенде, JS/MapKit на клиенте
# (передаются через --dart-define в CI, тут только для документации).
YANDEX_GEOCODER_API_KEY=942e9f13-0fec-48c2-bb23-3773b2939359
YANDEX_JS_API_KEY=d7e4aaa8-ea6e-441d-98e0-e17c20d92e03
YANDEX_MAPKIT_API_KEY=775d9148-243c-4cb6-86db-f1a1a057bb6f

# ─── Telegram bot ──────────────────────────────────────────────────────────
TELEGRAM_BOT_USERNAME=Maximov_ai_bot
TELEGRAM_BOT_TOKEN=8636274169:AAFtX-ZGY7AROaVD-DSUPHRr3Jn6eDihiJE
# Любая случайная строка >= 32 символов. Caddy/Telegram передадут её в
# заголовке X-Telegram-Bot-Api-Secret-Token, бэкенд сверит. Защита от
# спуфинга webhook'ов.
TELEGRAM_WEBHOOK_SECRET=__GENERATE_ME__

# ─── Налоговая ──────────────────────────────────────────────────────────────
# Для проверки СТИР курьера. На staging — mock.
TAX_API_BASE=https://api.soliq.uz
TAX_API_KEY=
USE_MOCK_TAX=true

# ─── Опционально ────────────────────────────────────────────────────────────
# Sentry — выставь DSN из https://sentry.io/settings/projects/<proj>/keys/
SENTRY_DSN=

# Интервал авто-синка меню партнёров (мс). 15 минут по умолчанию.
INTEGRATION_SYNC_INTERVAL_MS=900000

# Mock-flags для POS-адаптеров. Поставь 0 когда у партнёра появится sandbox.
MOCK_IIKO=1
MOCK_POSTER=1
