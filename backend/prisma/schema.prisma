// Prisma schema for TezKetKaz
// To use PostgreSQL in production, change `provider = "sqlite"` to `provider = "postgresql"`
// and update DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String?
  avatarUrl       String?

  // Roles
  isBuyer         Boolean  @default(true)
  isCourier       Boolean  @default(false)
  isShop          Boolean  @default(false)
  isAdmin         Boolean  @default(false)

  // Localization & preferences
  locale          String   @default("uz") // uz | ru | en
  notificationPrefs String? // JSON: { promo: bool, orderUpdates: bool, sound: bool }

  // Courier verification
  courierStatus   String   @default("none") // none | pending | approved | rejected
  stir            String?  // ИНН Узбекистана (9 цифр)
  passportSeries  String?
  selfEmployedCert String?

  // Shop linkage (one user can manage multiple shops via ShopMember)
  shopMemberships ShopMember[]

  // Relations
  buyerOrders    Order[]    @relation("BuyerOrders")
  courierOrders  Order[]    @relation("CourierOrders")
  addresses      Address[]
  notifications  Notification[]
  otpCodes       OtpCode[]
  fcmTokens      FcmToken[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]

  // Courier stats
  rating         Float    @default(5.0)
  ordersCount    Int      @default(0)

  // Courier real-time state (Phase 2). Persisted so it survives server
  // restarts; live position is mirrored in Redis with TTL=15min.
  isOnline       Boolean  @default(false)
  lastSeenAt     DateTime?
  activeOrderId  String?

  // Phase 2 relations
  shifts         CourierShift[]
  dispatchOffers DispatchOffer[]

  // Phase 3 relations
  loyalty            LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
  couponRedemptions  CouponRedemption[]
  reviewsAuthored    Review[]      @relation("Reviewer")
  chatMessagesSent   ChatMessage[] @relation("ChatSender")
  chatMessagesRecv   ChatMessage[] @relation("ChatReceiver")

  // Phase 6 relations
  paymentMethods     PaymentMethod[]
  verificationDocs   VerificationDocument[]

  // Phase 7 — country code drives currency, VAT rate, payment provider mix.
  // ISO 3166-1 alpha-2: UZ (default) | KZ | KG | RU.
  country        String   @default("UZ")

  // Phase 7 relations
  membership     Membership?
  favorites      Favorite[]
  bannerImpressions BannerImpression[]

  // Referral (Phase 3 loyalty)
  referralCode   String?  @unique
  referredById   String?
  referredBy     User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]   @relation("Referrals")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isAdmin])
  @@index([isCourier, courierStatus])
  @@index([isOnline, courierStatus])
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime @default(now())

  @@index([phone])
}

model FcmToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  platform  String   // android | ios | web
  lastSeenAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  jti           String   @unique // unique JWT id
  expiresAt     DateTime
  revokedAt     DateTime?
  replacedById  String?  // chain: rotated tokens point to next
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actor      User?    @relation(fields: [actorId], references: [id])
  actorId    String?
  action     String   // e.g. "courier.approve", "order.refund"
  targetType String?  // "User" | "Order" | "Shop" | etc.
  targetId   String?
  metadata   String?  // JSON
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// Idempotency table for payment webhooks — prevents double-processing
// the same callback if a provider retries.
model ProcessedWebhook {
  id          String   @id @default(uuid())
  provider    String   // "click" | "payme" | "uzum"
  externalId  String   // provider's transaction id
  orderId     String?
  payload     String   // JSON snapshot of body
  result      String   // JSON snapshot of our response
  createdAt   DateTime @default(now())

  @@unique([provider, externalId])
  @@index([orderId])
}

model Address {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  label     String   // Уй, Иш и т.д.
  fullAddress String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  comment   String?

  // Detailed delivery instructions (entrance, floor, apt, intercom)
  entrance     String?
  floor        String?
  apartment    String?
  intercom     String?
  instructions String?
}

model Shop {
  id          String   @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  address     String
  lat         Float?
  lng         Float?
  phone       String?

  // grocery | restaurant | pharmacy | electronics
  vertical    String   @default("grocery")

  isActive    Boolean  @default(true)
  rating      Float    @default(5.0)

  // Working hours
  openTime    String   @default("09:00")
  closeTime   String   @default("22:00")

  // Delivery economics (override defaults from env)
  deliveryBaseFee Float?
  deliveryPerKm   Float?
  freeDeliveryKm  Float?
  minOrderAmount  Float?

  // Phase 6 — multi-currency framework. Active values: UZS for Uzbekistan
  // launch. KZT/KGS activated in Phase 7 when expanding to KZ/KG.
  currency    String   @default("UZS")

  members     ShopMember[]
  products    Product[]
  orders      Order[]
  zones       DeliveryZone[]
  workingHours ShopWorkingHours[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vertical])
  @@index([isActive])
}

// Phase 6 — working hours per day-of-week. One row per (shop, dayOfWeek).
// Multiple rows allowed for split shifts (e.g., lunch break).
model ShopWorkingHours {
  id        String   @id @default(uuid())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId    String

  // 0=Sunday, 1=Monday, ..., 6=Saturday (matches JS Date.getDay())
  dayOfWeek Int

  // "HH:MM" 24h. Crossing midnight allowed: endsAt < startsAt means closes
  // next day (e.g. starts 18:00, ends 02:00 next morning).
  startsAt  String
  endsAt    String

  // True if shop is closed all day (overrides startsAt/endsAt).
  isClosed  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, dayOfWeek])
}

// Delivery zone polygon for a shop. Stored as JSON ring of [lat,lng] points
// because we're on SQLite. Postgres+PostGIS migration replaces with
// geometry(Polygon, 4326).
model DeliveryZone {
  id          String   @id @default(uuid())
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      String
  name        String

  // JSON: [[lat1,lng1],[lat2,lng2],...]. Closed implicitly (last==first).
  polygon     String

  baseFee     Float    @default(12000)
  perKmFee    Float    @default(2000)
  freeKm      Float    @default(2)        // first N km included in baseFee
  minOrder    Float    @default(0)

  // Optional time-bounded availability (e.g. zone only active 8-22)
  startsAt    String?  // "HH:MM"
  endsAt      String?  // "HH:MM"

  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, isActive])
}

// Courier shift (start/end of an availability session).
model CourierShift {
  id            String    @id @default(uuid())
  courier       User      @relation(fields: [courierId], references: [id])
  courierId     String

  startedAt     DateTime  @default(now())
  endedAt       DateTime?

  // Optional zones the courier accepted to work in this shift.
  // JSON: [zoneId1, zoneId2, ...]. Empty = any.
  zoneIds       String?

  totalEarned   Float     @default(0)
  totalOrders   Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([courierId, endedAt])
}

// Time-bounded surge / discount factor for a vertical or zone.
model PricingRule {
  id          String   @id @default(uuid())
  vertical    String?  // null = global
  zoneId      String?  // null = all zones in vertical

  surgeFactor Float    @default(1.0)
  reason      String   // "rain" | "peak_hours" | "low_supply" | "promo"

  validFrom   DateTime
  validUntil  DateTime

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([vertical, isActive, validFrom, validUntil])
}

// Dispatch offer ledger — every push to a courier is recorded so we can
// retry, audit, and rank couriers by acceptance rate.
model DispatchOffer {
  id         String   @id @default(uuid())
  orderId    String
  courier    User     @relation(fields: [courierId], references: [id])
  courierId  String

  // pending | accepted | declined | timed_out | superseded
  status     String   @default("pending")

  score      Float    // composite ranking score at offer time
  distanceKm Float?
  expiresAt  DateTime

  // Phase 8 — Wolt-tier transparency: estimated tip the buyer is likely to
  // leave (heuristic from shop's recent tip-rate or rolling avg per buyer).
  // Surfaced to the courier in the offer banner.
  tipEstimate Float    @default(0)

  // Phase 8 — Optional batch this offer is for. When non-null the courier
  // accepts a 2-3 order pickup chain rather than a single delivery.
  batchId    String?

  offeredAt  DateTime @default(now())
  respondedAt DateTime?

  @@unique([orderId, courierId])
  @@index([orderId, status])
  @@index([courierId, offeredAt])
  @@index([batchId])
}

// Hierarchical category tree. Categories can be global (shopId = null) or
// shop-scoped. A product references at most one category.
model Category {
  id        String   @id @default(uuid())
  parentId  String?
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  // grocery | restaurant | pharmacy | electronics
  vertical  String

  // Optional: when set, category belongs to a single shop's menu.
  shopId    String?

  slug      String
  nameUz    String
  nameRu    String
  nameEn    String?
  iconUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, shopId])
  @@index([vertical, isActive])
  @@index([parentId])
  @@index([shopId])
}

model ShopMember {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String
  role   String @default("manager") // owner | manager | staff

  @@unique([userId, shopId])
}

model Product {
  id            String   @id @default(uuid())
  shop          Shop     @relation(fields: [shopId], references: [id])
  shopId        String
  name          String
  nameUz        String
  description   String?
  ingredients   String?  // Состав (для еды и косметики)
  price         Float
  discountPrice Float?
  unit          String   // кг, шт, л

  // Legacy free-text label (produce, meat, dairy, bakery, drinks, grocery).
  // Kept for backwards compatibility; new code uses categoryRef.
  category      String

  // Structured category (Phase 1). Optional for legacy rows.
  categoryRef   Category? @relation(fields: [categoryId], references: [id])
  categoryId    String?

  imageUrl      String
  isAvailable   Boolean  @default(true)
  stock         Int      @default(100)

  // Quick lowercased copy of name+nameUz+description for LIKE-search on SQLite
  // (and a tsvector-backed column on Postgres later).
  searchText    String?

  modifierGroups ProductModifierGroup[]
  orderItems    OrderItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shopId])
  @@index([category])
  @@index([categoryId])
  @@index([isAvailable])
}

// Modifier groups attached to a product. E.g. "Size" with min=1 max=1 options
// "Small/Medium/Large", or "Toppings" with min=0 max=5 options.
model ProductModifierGroup {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  nameUz    String
  nameRu    String
  nameEn    String?

  // 0 = optional. Number of options the buyer must pick.
  minSelect Int      @default(0)
  maxSelect Int      @default(1)
  sortOrder Int      @default(0)

  options   ProductModifierOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductModifierOption {
  id        String   @id @default(uuid())
  group     ProductModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   String

  nameUz    String
  nameRu    String
  nameEn    String?

  // Added to the product price when this option is selected.
  priceDelta  Float    @default(0)
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)

  @@index([groupId])
}

model Order {
  id              String   @id @default(uuid())

  // Status flow:
  // pending → confirmed → collecting → readyForPickup → courierAssigned →
  // pickedUp → inDelivery → delivered  (or cancelled)
  status          String   @default("pending")
  orderNumber     String?  // e.g. K-247

  // Buyer
  buyer           User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId         String
  customerName    String   // Snapshot
  customerPhone   String

  // Shop
  shop            Shop     @relation(fields: [shopId], references: [id])
  shopId          String

  // Courier
  courier         User?    @relation("CourierOrders", fields: [courierId], references: [id])
  courierId       String?

  // Delivery
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?
  customerComment String?
  deliveryFee     Float    @default(12000)

  // Payment
  paymentMethod   String   // click | payme | uzumpay | cash
  isPaid          Boolean  @default(false)
  paymentRef      String?  // Transaction ID from payment provider

  // Pricing
  subtotal        Float
  total           Float
  courierReward   Float    @default(12000)

  // Phase 3 — promo + loyalty applied at checkout
  couponCode      String?
  discount        Float    @default(0)
  loyaltyEarned   Int      @default(0)   // points credited on delivery
  loyaltySpent    Int      @default(0)   // points debited at checkout

  // Phase 3 — scheduled delivery (null = ASAP)
  scheduledFor    DateTime?
  scheduledOrder  ScheduledOrder?

  // Phase 4 — refunds + disputes
  refundedAt      DateTime?
  refundedAmount  Float    @default(0)
  refundReason    String?
  dispute         Dispute?

  // Phase 6 — tip + saved-payment-method linkage
  tipAmount       Float    @default(0)
  tipPaidAt       DateTime?
  paymentMethodId String?    // null = legacy per-order method (cash, hosted Click flow, etc.)
  paymentMethod_  PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  // Currency snapshot at order time (mirrors Shop.currency).
  currency        String   @default("UZS")

  // Phase 7 — VAT/НДС snapshot. taxRate is the percentage applied (e.g. 0.12),
  // taxAmount is what was added on top of subtotal (in major units of currency).
  taxRate         Float    @default(0)
  taxAmount       Float    @default(0)

  // Phase 8 — stacked dispatch. When set, this order is part of a batch
  // the same courier picked up together. Null for solo deliveries.
  batchId         String?
  batch           OrderBatch? @relation(fields: [batchId], references: [id])
  // Position within the batch's pickup+delivery sequence (0,1,2...). Null
  // for solo orders or when not yet sequenced.
  batchSequence   Int?

  // Items
  items           OrderItem[]

  // Phase 3 relations
  reviews         Review[]
  chatMessages    ChatMessage[]

  // Timestamps for analytics
  createdAt       DateTime @default(now())
  acceptedAt      DateTime?
  readyAt         DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?

  // Rating after delivery (legacy quick-rating; richer reviews in Review model)
  buyerRating     Int?    // 1-5
  buyerReview     String?
  courierRating   Int?    // Курьер ставит оценку покупателю
  shopRating      Int?    // Покупатель ставит оценку магазину

  @@index([buyerId])
  @@index([shopId])
  @@index([courierId])
  @@index([status])
  @@index([scheduledFor])
}

model OrderItem {
  id          String  @id @default(uuid())
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  product     Product @relation(fields: [productId], references: [id])
  productId   String
  productName String  // Snapshot at time of order
  quantity    Int
  price       Float   // Final unit price (base + modifiers) at order time
  basePrice   Float?  // Snapshot of product price (without modifiers)
  total       Float

  // JSON snapshot of selected modifiers at order time. Format:
  // [{ groupId, groupName, optionId, optionName, priceDelta }, ...]
  modifiers   String?
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  type      String   // order_update, promo, system, chat
  data      String?  // JSON payload
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ── Phase 3: promo, loyalty, reviews, chat, scheduled orders ────────────────

// Promo codes. `code` is the human-readable identifier and primary key.
model Coupon {
  code         String   @id
  // PERCENT (value is 1-100), FIXED (value is UZS amount), FREE_DELIVERY (value=0)
  type         String
  value        Float    @default(0)

  minOrder     Float?
  maxDiscount  Float?

  validFrom    DateTime
  validUntil   DateTime

  // Total redemptions across all users; null = unlimited.
  usageLimit   Int?
  usagePerUser Int      @default(1)
  usedCount    Int      @default(0)

  // Optional scoping: if both null, applies globally.
  vertical     String?
  shopId       String?

  // First-order-only flag (e.g. WELCOME20).
  firstOrderOnly Boolean @default(false)

  isActive     Boolean  @default(true)

  redemptions  CouponRedemption[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, validFrom, validUntil])
  @@index([vertical])
  @@index([shopId])
}

model CouponRedemption {
  id         String   @id @default(uuid())
  coupon     Coupon   @relation(fields: [couponCode], references: [code])
  couponCode String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  orderId    String
  discount   Float
  redeemedAt DateTime @default(now())

  @@unique([couponCode, orderId])
  @@index([userId])
  @@index([orderId])
}

// Per-user loyalty wallet. Tier upgrade rules live in src/services/loyalty.js.
model LoyaltyAccount {
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @id

  // bronze | silver | gold | platinum
  tier         String   @default("bronze")
  points       Int      @default(0)
  cashback     Float    @default(0)

  lifetimeSpent Float   @default(0)   // drives tier promotions

  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model LoyaltyTransaction {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  // earn_order | spend_order | bonus_referral | refund | promo | adjustment
  reason    String
  delta     Int       // signed; positive earns, negative spends
  orderId   String?
  metadata  String?   // JSON
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
}

// Polymorphic review: target may be a Shop, a Courier (User), or a Product.
model Review {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewerId  String

  // SHOP | COURIER | PRODUCT
  targetType  String
  targetId    String

  rating      Int      // 1..5
  text        String?
  // JSON array of uploaded image URLs.
  photos      String?
  isVisible   Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orderId, reviewerId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([reviewerId])
}

// Chat messages between buyer and courier (or shop) within an order.
model ChatMessage {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String

  sender      User     @relation("ChatSender", fields: [senderId], references: [id])
  senderId    String
  receiver    User     @relation("ChatReceiver", fields: [receiverId], references: [id])
  receiverId  String

  text        String?
  imageUrl    String?
  isRead      Boolean  @default(false)
  readAt      DateTime?

  createdAt   DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([receiverId, isRead])
}

// Scheduled-for-later order. Dispatcher activation runs prep+ETA before the slot.
model ScheduledOrder {
  id              String   @id @default(uuid())
  order           Order    @relation(fields: [orderId], references: [id])
  orderId         String   @unique
  scheduledFor    DateTime
  reminderSentAt  DateTime?
  activatedAt     DateTime?
  // pending | activated | cancelled | completed
  status          String   @default("pending")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scheduledFor, status])
}

// ── Phase 4: payouts, disputes ──────────────────────────────────────────────

// Weekly payout aggregate — one row per (recipient, weekStart). Generated
// by the payouts BullMQ job; admin marks paid after manual transfer.
model Payout {
  id          String   @id @default(uuid())

  // 'courier' | 'shop'
  recipientType String
  recipientId   String

  // Inclusive Monday 00:00 UTC, exclusive next Monday.
  periodStart   DateTime
  periodEnd     DateTime

  // Sum of Order.courierReward (couriers) or
  //   sum(subtotal*(1-commission)) - refunds (shops).
  grossAmount   Float
  commission    Float    @default(0)
  refundsTotal  Float    @default(0)
  netAmount     Float

  ordersCount   Int      @default(0)

  // pending | requested | paid | failed | cancelled
  // 'requested' is set by the courier's instant-payout flow (Phase 8.5);
  // admin then transitions to 'paid' or 'failed'.
  status        String   @default("pending")
  paidAt        DateTime?
  txnRef        String?
  notes         String?

  // Phase 8.5 — instant payout request timestamp + linked courier (for
  // off-cycle requests that don't follow the weekly aggregate).
  requestedAt   DateTime?
  // 'weekly' | 'instant'. weekly is the legacy cron-generated payout.
  source        String   @default("weekly")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([recipientType, recipientId, periodStart])
  @@index([recipientType, status])
  @@index([periodStart])
}

// Customer dispute over an order (missing items, wrong food, late, damaged).
model Dispute {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String   @unique

  openedById  String
  // 'missing_items' | 'wrong_items' | 'late' | 'damaged' | 'other'
  reason      String
  description String?
  // JSON array of evidence URLs (photos/videos).
  evidence    String?

  // open | under_review | resolved | rejected
  status      String   @default("open")

  resolution  String?  // 'refund' | 'partial_refund' | 'replacement' | 'rejected' | 'no_action'
  refundAmount Float   @default(0)
  resolvedById String?
  resolvedAt  DateTime?
  resolutionNote String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([openedById])
}

// ── Phase 6: payment methods (tokenized cards) + KYC documents ──────────────

// Saved tokenized payment method. Provider stores the actual PAN; we keep
// only the display fields (brand, last4, expiry) and the provider-side
// token id for recurring charges.
model PaymentMethod {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String

  // 'click' | 'payme' | 'uzum' | 'kaspi' (KZ, Phase 7) | 'cash'
  provider     String

  // Provider-side token / saved-card id used to charge without re-entering PAN.
  // null for cash-on-delivery method.
  providerId   String?

  // Display-only fields. Never store raw PAN.
  brand        String?  // visa | mastercard | uzcard | humo
  last4        String?
  expiryMonth  Int?
  expiryYear   Int?

  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)

  // Orders that used this payment method (back-relation only).
  orders       Order[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, isActive])
}

// KYC / verification document upload. Used by couriers (passport, STIR cert)
// and shops (license, tax cert).
model VerificationDocument {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String

  // 'passport_front' | 'passport_back' | 'selfie' | 'self_employed_cert' |
  // 'shop_license' | 'shop_tax_cert' | 'driver_license'
  type            String

  // URL of the uploaded image. Currently /uploads/verification/* served by
  // backend; will move to Cloudflare R2 in Phase 9.
  url             String

  // pending | approved | rejected
  status          String   @default("pending")

  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, type])
  @@index([status])
}

// ── Phase 7: subscription, banners, favorites ───────────────────────────────

// Wolt+ / Yandex Plus style membership. One row per user; tier upgrades
// rewrite this row (we do not keep tier history here — that's in
// LoyaltyTransaction with a 'membership' reason).
model Membership {
  id                String   @id @default(uuid())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String   @unique

  // 'plus' (basic perks) | 'pro' (free delivery + priority support)
  tier              String   @default("plus")

  // 'active' | 'past_due' | 'cancelled' | 'expired'
  status            String   @default("active")

  // ISO currency snapshot of the price the user signed up at (e.g. "UZS").
  currency          String   @default("UZS")

  // Price per renewal period in major units. 30000 UZS / month at launch.
  periodAmount      Float

  // 'monthly' | 'yearly'
  billingPeriod     String   @default("monthly")

  startedAt         DateTime @default(now())
  currentPeriodEnd  DateTime
  cancelledAt       DateTime?
  // When status='past_due' how many billing retries we've done. Reset on success.
  failedRenewals    Int      @default(0)
  lastChargeAt      DateTime?
  lastChargeError   String?

  autoRenew         Boolean  @default(true)
  paymentMethodId   String?  // saved card to charge on renewal

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, currentPeriodEnd])
}

// Promo banners shown on buyer home / vertical landing. Admin-managed.
model Banner {
  id            String   @id @default(uuid())

  titleUz       String
  titleRu       String
  titleEn       String?

  subtitleUz    String?
  subtitleRu    String?
  subtitleEn    String?

  imageUrl      String

  // Where tapping the banner sends the user. Examples:
  //   /buyer/shops?vertical=restaurant
  //   /shop/SHOP_ID
  //   /buyer/promo?code=WELCOME20
  // Null = decorative banner (no tap action).
  deepLink      String?

  // 'all' | 'grocery' | 'restaurant' | 'pharmacy' | 'electronics'
  vertical      String   @default("all")

  // ISO country filter ("UZ", "KZ", "KG"). Null = all.
  country       String?

  priority      Int      @default(0)
  isActive      Boolean  @default(true)

  validFrom     DateTime?
  validUntil    DateTime?

  // Optional: track impressions/clicks for the admin dashboard.
  impressions   BannerImpression[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, priority])
  @@index([vertical, isActive])
  @@index([country])
}

model BannerImpression {
  id        String   @id @default(uuid())
  banner    Banner   @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  bannerId  String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  // 'view' | 'click'
  kind      String
  createdAt DateTime @default(now())

  @@index([bannerId, kind, createdAt])
  @@index([userId, kind])
}

// Per-user favorite product. Shop-favorites would be a similar model with
// shopId instead — skip for now, can be added in Phase 8 if demand exists.
model Favorite {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  // Either productId OR shopId is set; never both.
  productId  String?
  shopId     String?

  createdAt  DateTime @default(now())

  @@unique([userId, productId])
  @@unique([userId, shopId])
  @@index([userId])
}

// ── Phase 8: stacked dispatch (multi-pickup batch) ──────────────────────────

// A bundle of 2-3 orders the same courier accepted together. The dispatcher
// builds a batch when several pending orders share a zone and overlap in
// pickup time; the courier sees one offer that pays the sum of rewards.
model OrderBatch {
  id              String   @id @default(uuid())
  courierId       String?  // assigned when the batch is accepted
  // 'pending' | 'accepted' | 'in_progress' | 'completed' | 'cancelled'
  status          String   @default("pending")

  // Total orders in the batch when offered (locked in at offer time).
  totalDeliveries Int

  // How many of those have reached `delivered` status. UI uses this for the
  // "2/3 deliveries done" indicator on courier_home_screen.
  deliveriesCompleted Int  @default(0)

  // Sum of Order.courierReward + tip across all orders, snapshotted when the
  // batch is offered so courier sees the right pay before accepting.
  estimatedReward Float    @default(0)

  pickedUpAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  // Member orders.
  orders          Order[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([courierId, status])
  @@index([status])
}
