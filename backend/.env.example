# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Postgres is required for both dev and tests as of Phase 13.1.1.
# Easiest setup: `docker compose up -d db` from the repo root, which starts
# a Postgres 16 instance using the credentials below. Alternatively install
# Postgres locally and create a `tezketkaz` DB owned by `tezketkaz`.
DATABASE_URL="postgresql://tezketkaz:tezketkaz@localhost:5432/tezketkaz?schema=public"
FRONTEND_URL=http://localhost:3000

# ─── Auth (REQUIRED — no defaults in production) ────────────────────────────
JWT_SECRET=change-me-min-32-chars-please-use-pwgen
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ─── Redis (REQUIRED in production for sockets / blacklist / queues) ────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ─── SMS (Eskiz) ────────────────────────────────────────────────────────────
USE_MOCK_SMS=true
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# ─── Payments ───────────────────────────────────────────────────────────────
USE_MOCK_PAYMENTS=true

CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

PAYME_MERCHANT_ID=
PAYME_KEY=

UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

# ─── Phase 7 — Kazakhstan (Kaspi) ───────────────────────────────────────────
KASPI_MERCHANT_ID=
KASPI_SECRET=

# ─── Phase 7 — Kyrgyzstan (Click KG) ────────────────────────────────────────
CLICK_KG_MERCHANT_ID=
CLICK_KG_SERVICE_ID=
CLICK_KG_SECRET_KEY=

# ─── Phase 7 — Transactional email (Resend). Optional; absent ⇒ noop ────────
RESEND_API_KEY=

# ─── Maps ───────────────────────────────────────────────────────────────────
DGIS_API_KEY=

# ─── FCM ────────────────────────────────────────────────────────────────────
FCM_ENABLED=false
# Place serviceAccount as backend/firebase-admin.json (gitignored)

# ─── Tax verification (Uzbekistan STIR) ─────────────────────────────────────
USE_MOCK_TAX=true
TAX_API_BASE=https://api.soliq.uz
TAX_API_KEY=

# ─── Admin (legacy bootstrap; prefer User.isAdmin) ──────────────────────────
ADMIN_PHONES=

# ─── Dispatch ───────────────────────────────────────────────────────────────
COURIER_RADIUS_KM=5

# ─── Pricing defaults ───────────────────────────────────────────────────────
# Used when neither the matching DeliveryZone nor the Shop overrides a value.
DELIVERY_BASE_FEE=12000
DELIVERY_PER_KM=2000
DELIVERY_FREE_KM=2

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# Phase 5 observability
SENTRY_DSN=
GIT_COMMIT=
# Phase 12 — CI / release tagging. Either of these is used as the Sentry
# release ID; GIT_COMMIT takes precedence.
SENTRY_RELEASE=

# ─── Phase 12 — Yandex Routing API ─────────────────────────────────────────
# When set, services/routing.js calls Yandex for road-aware driving distance
# and ETA. When empty, falls back to haversine + 25 km/h heuristic.
YANDEX_ROUTING_KEY=

# ─── Storage (Phase 9 + Phase 13.1.2) ───────────────────────────────────────
# Where uploaded files (product images, KYC docs, banners, chat images) live.
#   local — files served from backend/uploads/ via /uploads/* route (default)
#   r2    — Cloudflare R2 bucket (S3 compatible, free tier 10 GB)
#   s3    — AWS S3 (or any S3 compatible API)
STORAGE_PROVIDER=local
# Used to build absolute URLs for files served by /uploads/* (local provider).
PUBLIC_URL=http://localhost:4000

# Required when STORAGE_PROVIDER=r2 or s3 (Phase 9 vars; new code prefers these)
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Public-facing CDN/bucket URL — what clients see in returned URLs.
# For R2: https://<account>.r2.cloudflarestorage.com path; or CDN mapping.
S3_PUBLIC_BASE=
