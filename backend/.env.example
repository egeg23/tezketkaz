# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL="file:./dev.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://user:pass@localhost:5432/tezketkaz"
FRONTEND_URL=http://localhost:3000

# ─── Auth (REQUIRED — no defaults in production) ────────────────────────────
JWT_SECRET=change-me-min-32-chars-please-use-pwgen
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ─── Redis (REQUIRED in production for sockets / blacklist / queues) ────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ─── SMS (Eskiz) ────────────────────────────────────────────────────────────
USE_MOCK_SMS=true
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# ─── Payments ───────────────────────────────────────────────────────────────
USE_MOCK_PAYMENTS=true

CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

PAYME_MERCHANT_ID=
PAYME_KEY=

UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

# ─── Maps ───────────────────────────────────────────────────────────────────
DGIS_API_KEY=

# ─── FCM ────────────────────────────────────────────────────────────────────
FCM_ENABLED=false
# Place serviceAccount as backend/firebase-admin.json (gitignored)

# ─── Tax verification (Uzbekistan STIR) ─────────────────────────────────────
USE_MOCK_TAX=true
TAX_API_BASE=https://api.soliq.uz
TAX_API_KEY=

# ─── Admin (legacy bootstrap; prefer User.isAdmin) ──────────────────────────
ADMIN_PHONES=

# ─── Dispatch ───────────────────────────────────────────────────────────────
COURIER_RADIUS_KM=5

# ─── Pricing defaults ───────────────────────────────────────────────────────
# Used when neither the matching DeliveryZone nor the Shop overrides a value.
DELIVERY_BASE_FEE=12000
DELIVERY_PER_KM=2000
DELIVERY_FREE_KM=2

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# Phase 5 observability
SENTRY_DSN=
GIT_COMMIT=
