<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>TezKetKaz</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>tezketkaz</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- Permissions -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>TezKetKaz uses your location to deliver groceries to you and show nearby shops.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>TezKetKaz uses your location to track delivery in real time.</string>
    <key>NSCameraUsageDescription</key>
    <string>TezKetKaz needs camera access to take photos of your delivery documents and avatar.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>TezKetKaz needs photo library access to select avatar and document photos.</string>
    <key>NSContactsUsageDescription</key>
    <string>TezKetKaz uses contacts to invite friends.</string>

    <!-- App Transport Security: разрешаем localhost для dev -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- URL schemes для url_launcher -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>tel</string>
        <string>https</string>
        <string>dgis</string>
        <string>yandexmaps</string>
        <string>yandexnavi</string>
    </array>

    <!-- Custom URL scheme для deep linking -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>uz.tezketkaz.app</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>tezketkaz</string>
            </array>
        </dict>
    </array>

    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <!-- Phase 13.1.6 — Firebase Messaging on iOS.
         Setting this to NO disables Firebase's automatic UIApplicationDelegate
         swizzling. We use flutter_local_notifications for foreground display
         and PushService.onTap for routing, both of which expect manual
         delegation of the APNs token. Required for FCM 11+. -->
    <key>FirebaseAppDelegateProxyEnabled</key>
    <false/>
</dict>
</plist>
