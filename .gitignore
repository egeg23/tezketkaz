# ─── Flutter ──────────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
# But keep the prebuilt web bundle so the backend can serve it without
# requiring Flutter on the deploy host. CI rebuilds this on every push.
!build/web/
!build/web/**
.idea/
.vscode/
*.iml
.flutter/
.metadata
pubspec.lock

# Generated — block every env variant so secrets never land in git.
.env
.env.*
!.env.example
!**/.env.example

# Coverage reports — regenerated by `flutter test --coverage`.
coverage/
!coverage/.gitkeep

# ─── Android ──────────────────────────────────────────────────────────────────
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks
*.keystore
# Generic key/cert blobs that should never be committed.
*.p8
*.p12
*.pem
*.pfx
*.mobileprovision
*.cer
google-services.json

# ─── iOS ──────────────────────────────────────────────────────────────────────
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/.vagrant/
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata
**/ios/.generated/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
GoogleService-Info.plist

# ─── Node (any subdir) ───────────────────────────────────────────────────────
node_modules/
**/node_modules/
# Keep backend/package-lock.json for reproducible deploys; ignore stray ones at root
/package-lock.json

# ─── Backend ─────────────────────────────────────────────────────────────────
backend/.env
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/test*.db
backend/prisma/test*.db-journal
backend/prisma/prisma/
backend/firebase-admin.json
# Generic Firebase / Google / Apple credential filenames that might land here.
firebase-admin*.json
**/firebase-admin*.json
GoogleService-Info.plist
play-store-key.json
**/play-store-key.json
# Anything matching `*.key` is sensitive (TLS private keys, EDS export files, …).
*.key
backend/uploads/products/
backend/uploads/verification/
backend/uploads/banners/
backend/uploads/exports/
backend/uploads/backups/
backend/uploads/delivery-photos/
backend/uploads/receipts/
!backend/uploads/.gitkeep

# ─── Next.js admin ───────────────────────────────────────────────────────────
admin-next/.next/
admin-next/out/
admin-next/tsconfig.tsbuildinfo

# ─── Next.js vendor ──────────────────────────────────────────────────────────
vendor-next/.next/
vendor-next/out/
vendor-next/tsconfig.tsbuildinfo

# ─── Stray dirs from past tooling glitch ─────────────────────────────────────
/{android/
/{lib/
/{src/

# ─── Local test artifacts ────────────────────────────────────────────────────
test_*.js
buyer_login.json

# ─── Fastlane ─────────────────────────────────────────────────────────────────
# Play Console service-account JSON is injected by CI from a secret and must
# never land in git. Locally, place it at fastlane/play-store-key.json.
fastlane/play-store-key.json
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/.env
# Gemfile.lock IS committed for reproducible CI — see Gemfile comment.

# ─── Claude Code (local) ──────────────────────────────────────────────────────
.claude/settings.local.json

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
